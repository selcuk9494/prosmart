{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build/web" }
    },
    {
      "src": "server/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "crons": [
    { "path": "/api/cron/pos/pull", "schedule": "10 0 * * *" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
